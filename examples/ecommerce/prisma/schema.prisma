generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  support
  customer
}

enum OrderStatus {
  pending
  processing
  shipped
  delivered
  cancelled
}

/// @vistal:description "A user account in the system"
model User {
  id         String   @id @default(uuid())
  name       String
  /// @vistal:description "User email address for login"
  email      String   @unique
  /// @vistal:sensitive
  password_hash String
  role       UserRole
  tenant_id  String
  created_at DateTime @default(now())

  orders Order[]
}

/// @vistal:description "A product available for purchase"
model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  /// @vistal:description "Unit price in cents"
  price       Decimal
  /// @vistal:description "Units currently in stock"
  stock       Int
  tenant_id   String
  created_at  DateTime @default(now())

  order_items OrderItem[]
}

/// @vistal:description "A customer purchase order"
model Order {
  id       String      @id @default(uuid())
  status   OrderStatus
  /// @vistal:description "Order total in cents"
  total    Decimal
  /// @vistal:sensitive
  internal_notes String?
  tenant_id      String
  created_at     DateTime @default(now())

  user_id  String
  customer User        @relation(fields: [user_id], references: [id])
  items    OrderItem[]
}

/// @vistal:description "A line item within an order"
model OrderItem {
  id         String  @id @default(uuid())
  quantity   Int
  /// @vistal:description "Price at time of purchase, in cents"
  unit_price Decimal

  order_id String
  order    Order   @relation(fields: [order_id], references: [id])

  product_id String
  product    Product @relation(fields: [product_id], references: [id])
}
