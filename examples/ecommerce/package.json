{
  "name": "valv-ecommerce-example",
  "version": "0.0.1",
  "private": true,
  "description": "End-to-end e-commerce example for valv",
  "scripts": {
    "start": "tsx index.ts",
    "mcp": "tsx mcp.ts",
    "dashboard": "tsx live-dashboard.ts",
    "db:start": "docker run -d --name valv-postgres -p 5432:5432 -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=valv_dev postgres:16-alpine || docker start valv-postgres",
    "db:stop": "docker stop valv-postgres",
    "db:reset": "docker stop valv-postgres && docker rm valv-postgres && npm run db:start",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "@prisma/client": "^5.0.0",
    "@valv/core": "*",
    "@valv/mcp-sdk": "*",
    "@valv/prisma": "*",
    "ai": "^6.0.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "ai": "^6.0.0",
    "prisma": "^5.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
