{
  "name": "@valv/mcp",
  "version": "0.1.1",
  "description": "Zero-config MCP server for any database — point it at a DATABASE_URL and let coding agents (Claude Code) query it safely, no SQL and no code",
  "keywords": [
    "mcp",
    "model context protocol",
    "claude code",
    "database",
    "postgres",
    "mysql",
    "sqlite",
    "prisma",
    "ai agent",
    "row-level security",
    "cli"
  ],
  "author": "Nicolò D'Addabbo <nicolodaddabbo@gmail.com> (https://nicolod.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vista-libs/vista.git",
    "directory": "packages/mcp"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "valv-mcp": "dist/cli.js"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@valv/core": "^0.3.0",
    "@valv/mcp-sdk": "^0.1.0",
    "@valv/prisma": "^0.3.0",
    "prisma": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
