{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    // node16 honors the MCP SDK's package "exports" map (the base config's
    // CommonJS/node10 resolution does not). Emit stays CommonJS because this
    // package has no "type": "module" — hence the .js suffixes on local imports.
    "module": "node16",
    "moduleResolution": "node16"
  },
  "include": ["src/**/*"]
}
