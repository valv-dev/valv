{
  "name": "@valv/mcp-sdk",
  "version": "0.2.0",
  "description": "Library to turn your app's database into an MCP server for coding agents (Claude Code) — adapter-agnostic, row-level security, zero SQL",
  "keywords": [
    "mcp",
    "model context protocol",
    "claude code",
    "ai agent",
    "llm",
    "access control",
    "authorization",
    "row-level security",
    "multi-tenant",
    "tool use",
    "prisma",
    "clickhouse",
    "typescript"
  ],
  "author": "Nicolò D'Addabbo <nicolodaddabbo@gmail.com> (https://nicolod.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vista-libs/vista.git",
    "directory": "packages/mcp-sdk"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "peerDependencies": {
    "@valv/core": "^0.4.0",
    "express": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
